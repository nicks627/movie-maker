# Optional local overrides for machines that do not use the default layout.
# Copy this file to `.env.local` and edit only the values you need.

# Project-local Python virtual environment.
# PYTHON_BIN=.venv\Scripts\python.exe
# PYTHON_BIN=.venv/bin/python3

# Override when VOICEVOX Core assets live outside the default vendor folder.
# VOICEVOX_CORE_ROOT=vendor\voicevox_core
# VOICEVOX_CORE_ROOT=vendor/voicevox_core

# Asset source API keys.
# Official press kits and Wikimedia Commons do not require API keys.
# PIXABAY_API_KEY=
# PEXELS_API_KEY=
# UNSPLASH_ACCESS_KEY=

# Optional binary overrides if ffmpeg / ffprobe are not available on PATH.
# FFMPEG_PATH=
# FFPROBE_PATH=
