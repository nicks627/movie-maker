{
  "name": "videokit",
  "version": "1.0.0",
  "description": "VideoKit video tool",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20 <24",
    "npm": ">=10"
  },
  "dependencies": {
    "@remotion/cli": "4.0.435",
    "@remotion/player": "^4.0.435",
    "@remotion/tailwind-v4": "4.0.435",
    "@remotion/zod-types": "^4.0.435",
    "axios": "^1.13.6",
    "get-audio-duration": "^4.0.1",
    "lucide-react": "^0.577.0",
    "node-fetch": "^3.3.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.435",
    "tailwindcss": "4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.435",
    "@remotion/eslint-config-flat": "4.0.435",
    "@remotion/renderer": "^4.0.435",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "^8.0.0"
  },
  "scripts": {
    "doctor": "node setup.mjs",
    "doctor:analysis": "node scripts/doctor-analysis.mjs",
    "doctor:assets": "node scripts/doctor-assets.mjs",
    "guide:genre": "node scripts/guide-genre.mjs",
    "setup:full": "node scripts/setup-full.mjs",
    "new:project": "node scripts/new-project.mjs",
    "setup": "npm run setup:full",
    "bootstrap:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bootstrap-local.ps1",
    "bootstrap:local": "npm run bootstrap:windows",
    "dev": "remotion studio",
    "dev:ui": "vite",
    "build": "remotion bundle",
    "render": "node scripts/render-video.mjs",
    "render:long": "node scripts/render-video.mjs --variant long",
    "render:short": "node scripts/render-video.mjs --variant short",
    "render:both": "node scripts/render-video.mjs --variant both",
    "analyze:youtube": "node scripts/analyze-youtube.mjs",
    "analyze:youtube:deep": "node scripts/analyze-youtube.mjs",
    "analyze:youtube:compare": "node scripts/analyze-youtube-compare.mjs",
    "subtitles:youtube": "node scripts/generate-youtube-subtitles.mjs",
    "generate:from-analysis": "node scripts/generate-from-analysis.mjs",
    "make:short": "node scripts/make-short.mjs --from long",
    "make:short:lead": "node scripts/make-short.mjs --from long --mode lead",
    "make:short:summary": "node scripts/make-short.mjs --from long --mode summary",
    "make:short:trim": "node scripts/make-short.mjs --from long --mode trim",
    "analyze:gameplay": "node scripts/analyze-gameplay.mjs",
    "apply:cut-plan": "node scripts/apply-cut-plan.mjs",
    "build:gameplay-commentary": "node scripts/build-gameplay-commentary.mjs",
    "assets:fetch": "node scripts/fetch-assets.mjs",
    "assets:fetch:national-intelligence": "node scripts/fetch-national-intelligence-assets.mjs",
    "review:report": "node scripts/generate-review-report.mjs",
    "review:text-audio": "node scripts/review-text-audio.mjs",
    "review:audio-balance": "node scripts/review-audio-balance.mjs",
    "review:layout": "node scripts/review-layout.mjs",
    "review:rhythm-visual": "node scripts/review-rhythm-visual.mjs",
    "review:preflight": "node scripts/review-preflight.mjs",
    "review:publish": "node scripts/review-publish-assets.mjs",
    "review:delivery": "node scripts/review-delivery.mjs",
    "review:apply": "node scripts/apply-review-feedback.mjs",
    "se:assign": "node assign-se.mjs --variant all",
    "se:dry": "node assign-se.mjs --variant all --dry-run",
    "se:apply": "node assign-se.mjs --apply-review",
    "generate:voices": "node generate-voices.mjs --variant long",
    "generate:voices:short": "node generate-voices.mjs --variant short --force",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "rebuild:script": "node scripts/rebuild_script.mjs",
    "clean:bg": "node scripts/enforce_rules.mjs"
  },
  "sideEffects": [
    "*.css"
  ]
}
